<isscript>
    var shopperAgentConfigJSON = JSON.stringify(pdict.shopperAgent);
</isscript>

<script type="text/javascript">
    // Secure JSON injection with proper escaping
    window.shopperAgentConfig = <isprint value="${shopperAgentConfigJSON}" encoding="off" />;
</script>

<script src="${URLUtils.staticURL('/js/shopperAgent.js')}"></script>
